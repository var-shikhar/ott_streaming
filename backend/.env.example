# Copy to .env and fill in what you need. Everything has a dev default —
# the app runs fully locally (SQLite + local media) with an empty .env.

# --- Database (Neon Postgres) ---
# Pooled URL (PgBouncer) for the app:
# DATABASE_URL=postgresql+psycopg://user:pass@ep-xxx-pooler.ap-southeast-1.aws.neon.tech/qisso?sslmode=require
# Direct (non-pooler) URL for Alembic migrations:
# DIRECT_DATABASE_URL=postgresql+psycopg://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/qisso?sslmode=require

# --- Auth ---
# JWT_SECRET=change-me-to-a-long-random-string
# ACCESS_TOKEN_MINUTES=15
# REFRESH_TOKEN_DAYS=30
# COOKIE_SECURE=true            # enable when serving over https

# --- URLs ---
# FRONTEND_ORIGIN=http://localhost:3000
# API_BASE_URL=http://localhost:8000

# --- Video storage: "local" (dev, default) or "s3" (prod) ---
# STORAGE_MODE=local
# MEDIA_ROOT=media
# AWS_REGION=ap-south-1
# S3_BUCKET=qisso-videos
# CLOUDFRONT_DOMAIN=dxxxxxxxxxxxx.cloudfront.net
# CLOUDFRONT_KEY_PAIR_ID=KXXXXXXXXXXXXX
# CLOUDFRONT_PRIVATE_KEY_PATH=./cloudfront_private_key.pem
# CDN_COOKIE_DOMAIN=.example.com   # parent domain shared by api + cdn hosts

# --- ImageKit (episode thumbnails; optional, falls back to local files) ---
# IMAGEKIT_PUBLIC_KEY=public_xxx
# IMAGEKIT_PRIVATE_KEY=private_xxx
# IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/yourid

# --- Razorpay (test mode keys from dashboard.razorpay.com) ---
# RAZORPAY_KEY_ID=rzp_test_xxx
# RAZORPAY_KEY_SECRET=xxx
# RAZORPAY_WEBHOOK_SECRET=whsec_xxx
